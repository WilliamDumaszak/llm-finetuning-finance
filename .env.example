# Copie para .env e preencha os valores.
# .env nunca é versionado (está no .gitignore).

# ── Azure (serving em produção) ───────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_MLFLOW_TRACKING_URI=       # Ex: https://sua-workspace.azureml.net

# ── Hugging Face ──────────────────────────────────────────────────────────────
HF_TOKEN=                        # Token com acesso a modelos gated (meta-llama)

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
